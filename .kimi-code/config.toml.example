# Kimi Code user-level hooks — applies to ALL projects
# Copy these sections to your ~/.kimi-code/config.toml

# PreToolUse: inject AGENTS.md before Bash (and extra PR review skill on gh pr create)
[[hooks]]
event = "PreToolUse"
matcher = "Bash"
command = "bash ~/.kimi-code/hooks/pre-tool-use.sh"
timeout = 10

# PostToolUse: fire-and-forget — notify/log after gh pr create succeeds.
# Cannot inject model context (observer event), but can send notifications.
[[hooks]]
event = "PostToolUse"
matcher = "Bash"
command = "bash ~/.kimi-code/hooks/post-tool-use.sh"
timeout = 5

# UserPromptSubmit: inject PR review skill when user asks to review a PR
[[hooks]]
event = "UserPromptSubmit"
command = "bash ~/.kimi-code/hooks/pre-tool-use.sh"
timeout = 10

# Optional: block rm -rf globally
[[hooks]]
event = "PreToolUse"
matcher = "Bash"
command = "bash -c 'read JSON; CMD=\"$(echo \"$JSON\" | jq -r \".tool_input.command // empty\")\"; if [[ \"$CMD\" == *\"rm -rf\"* ]]; then echo \"Error: rm -rf blocked by hook\" >&2; exit 2; fi; exit 0'"
timeout = 5
